  {
   "cell_type": "markdown",
   "metadata": {
    "id": "save_md"
   },
   "source": [
    "## Step 13 \u2014 Save Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "save_cell"
   },
   "outputs": [],
   "source": [
    "comp_df.to_csv('/content/drive/MyDrive/dl_comparison_results.csv', index=False)\n",
    "feat_df.to_csv('/content/drive/MyDrive/feature_importance.csv', index=False)\n"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "#LLM Integration\n",
    "\n",
    "try:\n",
    "    GEMINI_API_KEY = userdata.get('GEMINI_API_KEY')\n",
    "    if not GEMINI_API_KEY:\n",
    "        raise ValueError(\"Gemini API key not found in secrets\")\n",
    "except Exception as e:\n",
    "    print(\"Error loading API key:\", e)\n",
    "    print(\"\u2192 Go to https://aistudio.google.com/app/apikey to get a free key\")\n",
    "    print(\"\u2192 Then add it to Colab secrets as 'GEMINI_API_KEY'\")\n",
    "    raise\n",
    "\n",
    "genai.configure(api_key=GEMINI_API_KEY)\n",
    "model = genai.GenerativeModel('gemini-2.5-flash')\n",
    "\n",
    "\n",
    "best_model = results_experiment['A_TabNet']['model']\n",
    "X_test_used = X_full_test\n",
    "feat_names = clinical_cols + env_cols"
   ],
   "metadata": {
    "id": "evwaiSDVOTN-"
   },
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "source": [
    "import textwrap\n",
    "\n",
    "importances = best_model.feature_importances_\n",
    "top_k = 10\n",
    "top_idx = np.argsort(importances)[-top_k:][::-1]\n",
    "top_features = [(feat_names[i], importances[i]) for i in top_idx]\n",
    "\n",
    "# Prepare summary for prompt (top 8 usually enough)\n",
    "feature_summary = \"\\n\".join([\n",
    "    f\"- {name}: importance {imp:.4f}\"\n",
    "    for name, imp in top_features[:8]\n",
    "])\n",
    "\n",
    "# \u2500\u2500 Select a random sample patient from the test set \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "sample_idx = np.random.randint(0, len(X_test_used))\n",
    "sample_data = X_test_used[sample_idx].reshape(1, -1)\n",
    "sample_true = y_test[sample_idx]\n",
    "\n",
    "proba = best_model.predict_proba(sample_data)[:, 1][0]\n",
    "pred_class = int(proba >= 0.5)\n",
    "\n",
    "print(f\"\\nSample patient (index {sample_idx}):\")\n",
    "print(f\"True label: {'Positive' if sample_true else 'Negative'}\")\n",
    "print(f\"Predicted risk: {proba:.3f} \u2192 {'Positive' if pred_class else 'Negative'}\")\n",
    "\n",
    "# \u2500\u2500 Prepare prompt \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "prompt = f\"\"\"You are an expert pediatric allergist and respiratory epidemiologist.\n",
    "\n",
    "Patient profile summary:\n",
    "- Binary outcome being predicted: Ever had wheezing/asthma/rhinitis/eczema/hay fever/rash (positive = lifetime history of at least one)\n",
    "- Model predicted probability of positive outcome: {proba:.1%}\n",
    "- True label (for reference only \u2014 do NOT use in explanation): {'positive' if sample_true else 'negative'}\n",
    "\n",
    "Top contributing features according to the model (TabNet attention-based importance):\n",
    "{feature_summary}\n",
    "\n",
    "Clinical features start with symptoms (whez12, pnose12, rash12, etc.).\n",
    "Environmental features include diet (meat, fastfood, etc.), home exposures (smokers, catnow, etc.), siblings, breastfeeding, etc.\n",
    "\n",
    "Tasks:\n",
    "1. Provide a clear, empathetic, non-technical explanation (aimed at parent of 6\u20137 year old child) of why the model assigned this risk level. Emphasize modifiable environmental factors when they appear high in importance.\n",
    "2. List 2\u20134 realistic, evidence-based actionable recommendations that a clinician or parent could consider (focus on prevention/environmental control when relevant).\n",
    "3. Rate confidence in the environmental contribution: Low / Moderate / High \u2014 and briefly justify.\n",
    "4. Keep total response under 300 words. Use simple language. Do NOT add medical advice disclaimer \u2014 write as if speaking to a colleague/parent in a study context.\n",
    "\n",
    "Respond in this exact structure:\n",
    "**Explanation:**\n",
    "[your text]\n",
    "\n",
    "**Actionable Recommendations:**\n",
    "- [1]\n",
    "- [2]\n",
    "...\n",
    "\n",
    "**Environmental Contribution Confidence:**\n",
    "[Low/Moderate/High] \u2014 [one-sentence reason]\n",
    "\"\"\"\n",
    "\n",
    "# \u2500\u2500 Calling Gemini with PROPER TEXT WRAPPING \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "try:\n",
    "    response = model.generate_content(prompt)\n",
    "    response_text = response.text.strip()\n",
    "\n",
    "    print(\"\\n\" + \"=\"*80)\n",
    "    print(\"LLM CLINICAL EXPLANATION & RECOMMENDATIONS\".center(80))\n",
    "    print(\"=\"*80 + \"\\n\")\n",
    "\n",
    "    # Process each line with smart wrapping\n",
    "    for line in response_text.split('\\n'):\n",
    "        # Headers (bold sections like **Explanation:**)\n",
    "        if line.startswith('**') and line.endswith('**'):\n",
    "            print(line)  # Keep headers as-is\n",
    "            print()  # Add space after header\n",
    "\n",
    "        # Bullet points (actionable recommendations)\n",
    "        elif line.strip().startswith('-'):\n",
    "            # Wrap bullet points with hanging indent\n",
    "            wrapped = textwrap.fill(\n",
    "                line,\n",
    "                width=78,\n",
    "                initial_indent='',\n",
    "                subsequent_indent='  ',  # Indent continuation lines\n",
    "                break_long_words=False,\n",
    "                break_on_hyphens=False\n",
    "            )\n",
    "            print(wrapped)\n",
    "\n",
    "        # Regular paragraph text\n",
    "        elif line.strip():\n",
    "            wrapped = textwrap.fill(\n",
    "                line,\n",
    "                width=78,\n",
    "                break_long_words=False,\n",
    "                break_on_hyphens=False\n",
    "            )\n",
    "            print(wrapped)\n",
    "\n",
    "        # Empty lines (preserve spacing)\n",
    "        else:\n",
    "            print()\n",
    "\n",
    "    print(\"\\n\" + \"=\"*80)\n",
    "\n",
    "    # Save to Drive (original unwrapped version)\n",
    "    with open(f\"/content/drive/MyDrive/gemini_explanation_sample_{sample_idx}.txt\", \"w\") as f:\n",
    "        f.write(response_text)\n",
    "\n",
    "\n",
    "\n",
    "except Exception as e:\n",
    "    print(\"Error calling Gemini:\", e)\n",
    "    print(\"\u2192 Check your API key, rate limits, or try a different model\")"
   ],
   "metadata": {
    "id": "0rWqdVdil_Nh",
