   ],
   "source": [
    "# \u2500\u2500 Merge \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "JOIN_KEYS = ['country', 'centre', 'agegrp', 'school', 'serial']\n",
    "shared = [c for c in core_data.columns if c in envt_data.columns and c not in JOIN_KEYS]\n",
    "if shared:\n",
    "    envt_data = envt_data.drop(columns=shared)\n",
    "merged_df = pd.merge(core_data, envt_data, on=JOIN_KEYS, how='inner')\n",
    "print(f'Merged: {merged_df.shape}')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "MY2ztt5QFPAb",
    "outputId": "7b1ecd4b-6d33-4d6e-c47a-a96200898659"
   },
   "outputs": [
    {
     "output_type": "stream",
     "name": "stdout",
     "text": [
      "Final: 244,625 | Positive: 48.33%\n"
     ]
    }
   ],
   "source": [
    "# \u2500\u2500 Target \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "TARGET_CANDIDATES = ['whezev', 'asthmaev', 'pnoseev', 'hfeverev', 'eczemaev', 'rashev']\n",
    "target_present = [c for c in TARGET_CANDIDATES if c in merged_df.columns] #making sure that the target variables are indeed in the merged df\n",
    "\n",
    "for c in target_present:\n",
    "    merged_df[c] = merged_df[c].replace(9, np.nan) #removing the null values\n",
    "merged_df['target'] = merged_df[target_present].apply(\n",
    "    lambda row: 1 if (row == 1).any() else (np.nan if row.isna().all() else 0), axis=1 # 1 is postive for the disease, Nan for null values and 0 is negative for the disease\n",
    ")\n",
    "merged_df = merged_df.dropna(subset=['target']) #dropping th null values\n",
    "merged_df['target'] = merged_df['target'].astype(int)#coverting from float to integer so that it can be used for binary labelling\n",
    "print(f'Final: {len(merged_df):,}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "cRdj4h_MFVGz"
   },
   "outputs": [],
   "source": [
    "# \u2500\u2500 Features \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "CLINICAL_CANDIDATES = [\n",
    "    'whez12', 'nwhez12', 'awake12', 'speech12', 'exwhez12',\n",
    "    'pnose12', 'ieyes12', 'iactiv12', 'rash12', 'rclear12', 'rawake12',\n",
    "    'brth12', 'brth1m', 'exbrth12', 'exbrth1m',\n",
    "    'wwoken12', 'wwoken1m', 'cwoken12', 'cwoken1m',\n",
    "    'sabrth12', 'sabrth1m', 'cough12',\n",
    "]\n",
    "ENV_CANDIDATES = [\n",
    "    'meat', 'seafood', 'fruit', 'veges', 'pulses', 'cereal', 'pasta', 'rice',\n",
    "    'butter', 'margarin', 'nuts', 'potato', 'milk', 'eggs', 'fastfood',\n",
    "    'exercise', 'televis', 'cfelec', 'cfgas', 'cffire', 'hfelec', 'hfgas',\n",
    "    'hfwood', 'smokers', 'parayng', 'paranow', 'antibiot', 'oldsibs', 'yngsibs',\n",
    "    'cntrybir', 'yrslived', 'brstfed', 'trucfreq',\n",
    "    'catyng', 'catnow', 'dogyng', 'dognow', 'msnow', 'mncnow', 'fsnow', 'fncnow',\n",
    "]\n",
    "\n",
    "EXCLUDE = set(TARGET_CANDIDATES + ['target'] + JOIN_KEYS +\n",
    "              ['form', 'version', 'dint_day', 'dint_mth', 'dint_yr', 'validdat', 'envrques'])\n",
    "clinical_cols = [c for c in CLINICAL_CANDIDATES if c in merged_df.columns and c not in EXCLUDE]\n",
    "env_cols = [c for c in ENV_CANDIDATES if c in merged_df.columns and c not in EXCLUDE]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "a_i4b01vFeci",
    "outputId": "d0ac2d25-e395-47dc-fbcd-5dfd1710a302"
   },
   "outputs": [
    {
     "output_type": "stream",
     "name": "stdout",
     "text": [
      "Clinical: 12 | Environmental: 41\n"
     ]
    }
   ],
   "source": [
    "# \u2500\u2500 Clean \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "all_cols = clinical_cols + env_cols\n",
    "for col in all_cols:\n",
    "    merged_df[col] = pd.to_numeric(merged_df[col], errors='coerce')\n",
    "merged_df[all_cols] = merged_df[all_cols].replace(9, np.nan) #prevents overfitting by removing the n/a values\n",
    "\n",
    "clinical_cols = [c for c in clinical_cols if merged_df[c].isna().mean() <= 0.80]\n",
    "env_cols = [c for c in env_cols if merged_df[c].isna().mean() <= 0.80]\n",
    "all_cols = clinical_cols + env_cols\n",
    "\n",
    "CONT_COLS = ['oldsibs', 'yngsibs', 'yrslived', 'trucfreq']\n",
    "cont_present = [c for c in CONT_COLS if c in merged_df.columns]\n",
    "cat_cols = [c for c in all_cols if c not in cont_present]\n",
    "\n",
    "for col in cat_cols:\n",
    "    mode = merged_df[col].mode()\n",
    "    if not mode.empty:\n",
    "        merged_df[col] = merged_df[col].fillna(mode[0])\n",
    "for col in cont_present:\n",
    "    merged_df[col] = merged_df[col].fillna(merged_df[col].median())\n",
    "\n",
    "for col in cat_cols:\n",
    "    uniq = set(merged_df[col].dropna().unique())\n",
    "    if uniq.issubset({1, 2, 1.0, 2.0}):\n",
    "        merged_df[col] = (merged_df[col] == 1).astype(int)\n",
    "\n",
    "if cont_present:\n",
    "    scaler = StandardScaler()\n",
    "    merged_df[cont_present] = scaler.fit_transform(merged_df[cont_present])\n",
    "\n",
    "bad = [c for c in all_cols if merged_df[c].dtype == object]\n",
    "if bad:\n",
    "    for col in bad:\n",
    "        merged_df[col] = pd.to_numeric(merged_df[col], errors='coerce').fillna(0)\n",
    "\n",
    "print(f'Clinical: {len(clinical_cols)} | Environmental: {len(env_cols)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "split_cell",
    "outputId": "2f67a143-318c-4b30-884c-229faa8c2a57"
