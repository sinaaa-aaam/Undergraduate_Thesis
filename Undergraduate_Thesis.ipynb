   "outputs": [
    {
     "output_type": "stream",
     "name": "stdout",
     "text": [
      "Train: 171,335 | Val: 36,596 | Test: 36,694\n",
      "X_clin: (244625, 12) | X_full: (244625, 53)\n"
     ]
    }
   ],
   "source": [
    "# \u2500\u2500 Split \u2500\u2500\u2500\u2500\n",
    "y = merged_df['target'].values\n",
    "X_clin = merged_df[clinical_cols].values.astype(np.float32)\n",
    "X_full = merged_df[clinical_cols + env_cols].values.astype(np.float32)\n",
    "\n",
    "idx = np.arange(len(y))\n",
    "idx_trainval, idx_test = train_test_split(idx, test_size=0.15, stratify=y, random_state=SEED)\n",
    "y_trainval, y_test = y[idx_trainval], y[idx_test]\n",
    "idx_train, idx_val = train_test_split(idx_trainval, test_size=0.176, stratify=y_trainval, random_state=SEED)\n",
    "\n",
    "X_clin_train, X_clin_val, X_clin_test = X_clin[idx_train], X_clin[idx_val], X_clin[idx_test]\n",
    "X_full_train, X_full_val, X_full_test = X_full[idx_train], X_full[idx_val], X_full[idx_test]\n",
    "y_train, y_val, y_test = y[idx_train], y[idx_val], y[idx_test]\n",
    "\n",
    "print(f'Train: {len(y_train):,} | Val: {len(y_val):,} | Test: {len(y_test):,}')\n",
    "print(f'X_clin: {X_clin.shape} | X_full: {X_full.shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "models_md"
   },
   "source": [
    "##Pre-existing Model Definitions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "model_defs_cell"
   },
   "outputs": [],
   "source": [
    "def get_tabnet():\n",
    "\n",
    "    return TabNetClassifier(\n",
    "        n_d=32, n_a=32, n_steps=5, gamma=1.5,\n",
    "        lambda_sparse=1e-4, momentum=0.3,\n",
    "        optimizer_fn=torch.optim.Adam,\n",
    "        optimizer_params=dict(lr=2e-2),\n",
    "        scheduler_fn=torch.optim.lr_scheduler.StepLR,\n",
    "        scheduler_params=dict(step_size=50, gamma=0.9),\n",
    "        seed=SEED, verbose=0\n",
    "    )\n",
    "\n",
    "def get_tabpfn(subsample=20000):\n",
    "\n",
    "    device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "    return TabPFNClassifier(\n",
    "        device=device,\n",
    "        n_estimators=8,\n",
    "        random_state=SEED,\n",
    "        ignore_pretraining_limits=True  # allows >1000 rows\n",
    "    ), subsample\n",
    "\n",
    "def get_mlp():\n",
    "\n",
    "        return MLPClassifier(\n",
    "        hidden_layer_sizes=(128, 64, 32),\n",
    "        activation='relu', solver='adam',\n",
    "        alpha=0.0001, batch_size=256,\n",
    "        learning_rate='adaptive',\n",
    "        learning_rate_init=0.001,\n",
    "        max_iter=200, early_stopping=True,\n",
    "        validation_fraction=0.15,\n",
    "        n_iter_no_change=10,\n",
    "        random_state=SEED, verbose=False\n",
    "    )\n",
    "\n",
    "print('Model definitions ready')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "train_md"
   },
   "source": [
    "##Training Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "train_fns_cell"
   },
   "outputs": [],
   "source": [
    "def evaluate(y_true, y_prob):\n",
    "    y_pred = (y_prob >= 0.5).astype(int)\n",
    "    return {\n",
    "        'AUC': round(roc_auc_score(y_true, y_prob), 4),\n",
    "        'F1': round(f1_score(y_true, y_pred, zero_division=0), 4),\n",
    "        'Acc': round(accuracy_score(y_true, y_pred), 4)\n",
    "    }\n",
    "\n",
    "def train_tabnet(X_tr, X_va, X_te, y_tr, y_va, y_te):\n",
    "    model = get_tabnet()\n",
    "    model.fit(\n",
    "        X_tr, y_tr,\n",
    "        eval_set=[(X_tr, y_tr), (X_va, y_va)],\n",
    "        max_epochs=100, patience=20,\n",
    "        batch_size=1024, virtual_batch_size=256,\n",
    "        eval_metric=['auc']\n",
    "    )\n",
    "    y_prob = model.predict_proba(X_te)[:, 1]\n",
    "    return evaluate(y_te, y_prob), model\n",
    "\n",
    "def train_tabpfn(X_tr, X_va, X_te, y_tr, y_va, y_te, subsample=20000):\n",
    "    \"\"\"TabPFN with optional subsampling (slow on large datasets).\"\"\"\n",
    "    if len(y_tr) > subsample:\n",
    "        print(f'  [Subsampling {subsample:,} from {len(y_tr):,}]', end=' ')\n",
    "        X_tr, y_tr = resample(X_tr, y_tr, n_samples=subsample, stratify=y_tr, random_state=SEED)\n",
    "\n",
    "    model, _ = get_tabpfn(subsample)\n",
    "    model.fit(X_tr, y_tr)\n",
    "    y_prob = model.predict_proba(X_te)[:, 1]\n",
    "    return evaluate(y_te, y_prob), model\n",
    "\n",
    "def train_mlp(X_tr, X_va, X_te, y_tr, y_va, y_te):\n",
    "    model = get_mlp()\n",
    "    model.fit(X_tr, y_tr)\n",
    "    y_prob = model.predict_proba(X_te)[:, 1]\n",
    "    return evaluate(y_te, y_prob), model\n",
    "\n",
    "print('Training functions ready')"
   ]
  },
