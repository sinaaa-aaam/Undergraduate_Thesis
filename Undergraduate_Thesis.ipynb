   "source": [
    "NAMES = {\n",
    "    'A_TabNet': 'A: TabNet (Google)',\n",
    "    'B_TabPFN': 'B: TabPFN (Meta-learned)',\n",
    "    'C_MLP': 'C: MLPClassifier (sklearn)',\n",
    "}\n",
    "\n",
    "rows = []\n",
    "for key in NAMES.keys():\n",
    "    base = results_baseline[key]['metrics']\n",
    "    expr = results_experiment[key]['metrics']\n",
    "    rows.append({\n",
    "        'Model': NAMES[key],\n",
    "        'Baseline_AUC': base['AUC'],\n",
    "        'Experiment_AUC': expr['AUC'],\n",
    "        '\u0394AUC': round(expr['AUC'] - base['AUC'], 4),\n",
    "        'Baseline_F1': base['F1'],\n",
    "        'Experiment_F1': expr['F1'],\n",
    "        '\u0394F1': round(expr['F1'] - base['F1'], 4),\n",
    "        'Baseline_Acc': base['Acc'],\n",
    "        'Experiment_Acc': expr['Acc'],\n",
    "        '\u0394Acc': round(expr['Acc'] - base['Acc'], 4),\n",
    "})\n",
    "\n",
    "\n",
    "comp_df = pd.DataFrame(rows)\n",
    "print('\\n' + comp_df.to_string(index=False))\n",
    "\n",
    "print('\\n\u2500\u2500 Environmental Pattern Contribution \u2500\u2500')\n",
    "for _, r in comp_df.iterrows():\n",
    "    d = r['\u0394AUC']\n",
    "    verdict = 'IMPROVES' if d > 0.01 else ('\u26a0 DEGRADES' if d < -0.01 else '\u27a1 MINIMAL')\n",
    "    print(f\"  {r['Model']:<30} \u0394AUC={d:+.4f}  Acc={m['Acc']:.3f} {verdict}\")\n",
    "\n",
    "print(f\"\\nAverage \u0394AUC across all DL models: {comp_df['\u0394AUC'].mean():+.4f}\")"
   ]
